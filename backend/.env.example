# MongoDB Connection URI
# Replace with your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster.mongodb.net/hospital_management?retryWrites=true&w=majority

# Backend Server Port
PORT=5000

# JWT Secret (change this to a strong secret in production)
JWT_SECRET=your_super_secret_jwt_key_here

# Base URL for file uploads and backend access
# For local development: http://localhost:5000/api
# For physical device: http://YOUR_PC_IP:5000/api (e.g., http://192.168.1.100:5000/api)
BASE_URL=http://localhost:5000/api
